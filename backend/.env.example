APP_ENV=development
FRONTEND_ORIGINS=http://localhost:4000,http://127.0.0.1:4000
BACKEND_API_TOKEN=replace-with-a-long-random-token

LLM_API_KEY=replace-with-your-provider-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# 强提醒邮件（留空时站内提醒仍正常，页面显示“邮件未配置”）
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
ALERT_EMAIL_TO=
